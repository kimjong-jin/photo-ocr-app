# ✅ 이 파일은 Git에 올려도 안전합니다 (실제 값이 없음)
# 실제 환경변수는 .env.local (로컬 개발) 또는 Vercel 대시보드에서 설정하세요.

# ─── Vercel Serverless Functions (서버 전용 - 절대 VITE_ 접두사 붙이지 마세요) ───
GEMINI_API_KEY=your_gemini_api_key_here
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=your_sender_email@example.com
SENDER_NAME=KTL Photos

# ─── 선택사항 ───
CORS_ORIGIN=https://your-vercel-domain.vercel.app
ALLOW_ZIP=0
